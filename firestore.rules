rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidString(val, max) {
      return val is string && val.size() <= max;
    }

    // -------------------------------------------------------------------------
    // VALIDATION HELPERS
    // -------------------------------------------------------------------------
    function isValidClient(data) {
      return data.keys().hasAll(['userId', 'name', 'email', 'company'])
        && data.userId == request.auth.uid
        && isValidString(data.name, 100)
        && isValidString(data.email, 100)
        && isValidString(data.company, 100)
        && (data.get('avatar', '') is string && data.get('avatar', '').size() <= 500);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['userId', 'name', 'clientId', 'status'])
        && data.userId == request.auth.uid
        && isValidString(data.name, 100)
        && isValidId(data.clientId)
        && data.status in ['active', 'completed', 'on-hold', 'pending']
        && (data.get('budget', 0) is number)
        && (data.get('dueDate', '') is string)
        && (data.get('description', '') is string && data.get('description', '').size() <= 1000);
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'projectId', 'title', 'status'])
        && data.userId == request.auth.uid
        && isValidId(data.projectId)
        && isValidString(data.title, 200)
        && data.status in ['todo', 'in-progress', 'done']
        && (data.get('priority', 'medium') in ['low', 'medium', 'high'])
        && (data.get('dueDate', '') is string);
    }

    function isValidInvoice(data) {
      return data.keys().hasAll(['userId', 'clientId', 'amount', 'status'])
        && data.userId == request.auth.uid
        && isValidId(data.clientId)
        && data.amount is number
        && data.status in ['paid', 'unpaid', 'overdue', 'draft']
        && (data.get('date', '') is string)
        && (data.get('dueDate', '') is string);
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['userId', 'type', 'action', 'target', 'timestamp'])
        && data.userId == request.auth.uid
        && data.type in ['project', 'task', 'invoice', 'client']
        && isValidString(data.action, 50)
        && isValidString(data.target, 200)
        && (data.timestamp is string);
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['displayName'])
        && isValidString(data.displayName, 100)
        && (data.get('bio', '') is string && data.get('bio', '').size() <= 500)
        && (data.get('avatarUrl', '') is string && data.get('avatarUrl', '').size() <= 1000000); // 1MB limit for base64 if needed
    }

    // -------------------------------------------------------------------------
    // CATCH-ALL DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidUserProfile(incoming());
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(clientId) && isValidClient(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidClient(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /projects/{projectId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidProject(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidTask(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(invoiceId) && isValidInvoice(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidInvoice(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /activities/{activityId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(activityId) && isValidActivity(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidActivity(incoming())
        && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
